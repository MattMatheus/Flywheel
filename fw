#!/usr/bin/env bash
set -euo pipefail

root_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
tools_dir="$root_dir/flywheel/tools"

usage() {
  cat <<'EOF'
Flywheel workflow harness

Usage:
  ./fw <command> [args...]

Human-facing commands:
  help                 Show this help.
  commands             Show command mapping.
  status               Show branch, workflow state, lanes, and next stories.
  doctor               Run whole-harness health checks.
  validate             Validate workflow state.
  lanes                Show configured lanes.
  launch <stage>       Launch a stage.
  move <args...>       Move a workflow item between lanes.
  close-cycle <args..> Validate, run observer, index experience, commit.
  observer <args...>   Write observer report and JSON trace.
  experience <args...> Manage experience index.
  export <args...>     Plan tool-specific exports.
  plugins <args...>    List or validate plugins.
  hooks <args...>      List, validate, or run hooks.
  approval <args...>   Record approval-governed work.
  demo                 Seed a sample story into engineering intake.
  doc-test             Run harness doc tests.

Examples:
  ./fw status
  ./fw doctor
  ./fw close-cycle --cycle-id 20260610-example
  ./fw lanes
  ./fw launch engineering --format json
  ./fw move STORY-20260524-example active qa --reason "handoff ready"
  ./fw plugins doctor
  ./fw export plan all
EOF
}

commands() {
  cat <<'EOF'
Command mapping:
  status      -> flywheel/tools/flywheel_status.sh
  close-cycle -> flywheel/tools/close_cycle.sh
  doctor      -> flywheel/tools/flywheel_doctor.sh
  validate    -> flywheel/tools/validate_workflow_state.sh
  lanes       -> flywheel/tools/flywheel_lanes.sh
  launch      -> flywheel/tools/launch_stage.sh
  move        -> flywheel/tools/flywheel_state.sh move
  observer    -> flywheel/tools/run_observer_cycle.sh
  experience  -> flywheel/tools/flywheel_experience.sh
  export      -> flywheel/tools/flywheel_export.sh
  plugins     -> flywheel/tools/flywheel_plugins.sh
  hooks       -> flywheel/tools/flywheel_hooks.sh
  approval    -> flywheel/tools/flywheel_approval.sh
  demo        -> flywheel/tools/seed_demo_story.sh
  doc-test    -> flywheel/tools/run_doc_tests.sh
EOF
}

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

command="$1"
shift

case "$command" in
  help|-h|--help)
    usage
    ;;
  commands)
    commands
    ;;
  status)
    exec "$tools_dir/flywheel_status.sh" "$@"
    ;;
  close-cycle)
    exec "$tools_dir/close_cycle.sh" "$@"
    ;;
  doctor)
    exec "$tools_dir/flywheel_doctor.sh" "$@"
    ;;
  validate)
    exec "$tools_dir/validate_workflow_state.sh" "$@"
    ;;
  lanes)
    exec "$tools_dir/flywheel_lanes.sh" "$@"
    ;;
  launch)
    exec "$tools_dir/launch_stage.sh" "$@"
    ;;
  move)
    exec "$tools_dir/flywheel_state.sh" move "$@"
    ;;
  observer)
    exec "$tools_dir/run_observer_cycle.sh" "$@"
    ;;
  experience)
    exec "$tools_dir/flywheel_experience.sh" "$@"
    ;;
  export)
    exec "$tools_dir/flywheel_export.sh" "$@"
    ;;
  plugins)
    exec "$tools_dir/flywheel_plugins.sh" "$@"
    ;;
  hooks)
    exec "$tools_dir/flywheel_hooks.sh" "$@"
    ;;
  approval)
    exec "$tools_dir/flywheel_approval.sh" "$@"
    ;;
  demo)
    exec "$tools_dir/seed_demo_story.sh" "$@"
    ;;
  doc-test)
    exec "$tools_dir/run_doc_tests.sh" "$@"
    ;;
  *)
    echo "error: unknown command: $command" >&2
    echo "Run './fw help' for usage." >&2
    exit 2
    ;;
esac
